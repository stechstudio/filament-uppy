{
    "name": "stechstudio/filament-uppy",
    "description": "Uppy-based file uploader Filament form component.",
    "type": "library",
    "autoload": {
        "psr-4": {
            "STS\\FilamentUppy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "STS\\FilamentUppy\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "David Palmer",
            "email": "dp@stechstudio.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^3.0|^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.9",
        "stechstudio/laravel-uppy-companion": "^0.6"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0"
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/stechstudio/laravel-uppy-companion.git"
        }
    ],
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "STS\\FilamentUppy\\FilamentUppyServiceProvider"
            ]
        }
    }
}
